{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview:cf": "wrangler pages dev dist --port 8788",
    "build": "vite build",
    "db:init:d1:local": "npx wrangler d1 execute tokai-softtennis-db --local --file=./cloudflare/d1/schema.sql",
    "db:init:d1:remote": "npx wrangler d1 execute tokai-softtennis-db --remote --file=./cloudflare/d1/schema.sql",
    "export:csv": "node ./scripts/export-csv-to-d1.mjs",
    "export:supabase": "node ./scripts/export-supabase-to-d1.mjs",
    "generate:session-secret": "node ./scripts/generate-session-secret.mjs",
    "import:d1:local": "npx wrangler d1 execute tokai-softtennis-db --local --file=./cloudflare/d1/import-from-supabase.sql",
    "import:d1:remote": "npx wrangler d1 execute tokai-softtennis-db --remote --file=./cloudflare/d1/import-from-supabase.sql",
    "migrate:images:r2": "node ./scripts/migrate-images-to-r2.mjs",
    "seed:csv:d1:local": "npm run export:csv && npm run db:init:d1:local && npm run import:d1:local",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wrangler": "^4.13.2"
  }
}
